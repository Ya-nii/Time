/* 全局样式 */
page {
  background-color: #f8f9fa;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  color: #333;
  font-size: 28rpx;
}

/* 全局卡片样式 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 全局按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #007aff 0%, #5856d6 100%);
  color: #fff;
  border-radius: 50rpx;
  border: none;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary[disabled] {
  background: #cccccc;
  color: #fff;
}

/* 全局文字样式 */
.text-muted {
  color: #999;
  font-size: 24rpx;
}

.text-primary {
  color: #007aff;
}