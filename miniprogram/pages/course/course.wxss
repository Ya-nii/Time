/* 页面整体样式 */
.course-page {
  padding: 30rpx;
  background: #f7f8fa;
  min-height: 100vh;
}

/* 标题 */
.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

/* 输入卡片 */
.input-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

/* 文本输入框 */
textarea {
  min-height: 300rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
}

/* 解析按钮 */
.parse-btn {
  margin-top: 20rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  padding: 15rpx 0;
}

/* 结果卡片 */
.result-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

/* 结果卡片标题 */
.subtitle {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 课程项 */
.course-item {
  display: flex;
  justify-content: space-between;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #eee;
  font-size: 26rpx;
}
.course-item .time {
  color: #07c160;
  font-weight: 500;
}
.course-item .name {
  color: #666;
  flex: 1;
  text-align: right;
}

/* 空档期项 */
.free-item {
  padding: 15rpx 0;
  font-size: 28rpx;
  color: #07c160;
  border-bottom: 1rpx solid #eee;
}

/* 保存按钮 */
.save-btn {
  margin-top: 20rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  padding: 15rpx 0;
}