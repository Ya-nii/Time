/* ========== 正确：截图浅绿背景 ========== */
page {
  background-color: #F2F9F6 !important;
  padding-bottom: 50px;
  font-family: PingFang SC;
}

.page-container {
  padding: 20rpx 40rpx;
}

.tip {
  font-size: 23rpx;
  color: #6B8A82;
  width: 90%;
  text-align: center;
  margin: 30rpx auto 0 auto;
}

.top_tip {
  font-size: 28rpx;
  color: #6B8A82;
  width: 90%;
  text-align: left;
  margin-top: 30rpx;
}

/* 白色卡片 */
.box_text {
  background-color: #FFFFFF !important;
  text-align: center;
  padding: 300rpx 0;
  margin-top: 30rpx;
  color: #6B8A82;
  border-radius: 24rpx !important;
}

/* 按钮：截图同款淡绿色 */
.button {
  width: 300rpx;
  text-align: center;
  margin: 250rpx auto 0 auto;
  height: 80rpx;
  color: #3CB997 !important;
  border-radius: 20rpx !important;
  line-height: 80rpx;
  background-color: #E2F5EE !important;
}

.button_clear {
  width: 300rpx;
  text-align: center;
  margin: 0 auto;
  height: 80rpx;
  color: #3CB997 !important;
  border-radius: 20rpx !important;
  line-height: 80rpx;
  background-color: #E2F5EE !important;
}

.line {
  height: 1rpx;
  width: 100%;
  background-color: #D4E9E1;
}

/* 代码卡片 */
.code_box {
  text-align: center;
  background-color: #FFFFFF !important;
  margin-top: 30rpx;
  padding: 17rpx;
  border-radius: 24rpx !important;
}

.code_box_title {
  color: #6B8A82;
  font-size: 26rpx;
  margin-bottom: 20rpx;
  text-align: left;
}

.code_box_record {
  display: flex;
}

.code_box_record_title {
  width: 33%;
  font-size: 26rpx;
  color: #6B8A82;
  padding: 20rpx 0;
}

.code_box_record_detail {
  width: 25%;
  font-size: 26rpx;
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 标题文字 */
.title {
  margin-top: 16px;
  margin-bottom: 8px;
  font-size: 36rpx;
  font-weight: 500;
  color: #2A5548 !important;
}

.info {
  margin-top: 12px;
  font-size: 28rpx;
  font-weight: 400;
  color: #6B8A82 !important;
  line-height: 52rpx;
}

.img {
  width: 100%;
  border-radius: 20rpx !important;
}

.step-img {
  margin-top: 20rpx;
  border-radius: 20rpx !important;
}

.code_img {
  width: 360rpx;
  height: 360rpx;
}

.block {
  font-size: 16px;
  line-height: 40px;
}

/* 步骤标签绿色 */
.step-left {
  color: #FFF !important;
  background-color: #3CB997 !important;
  border: #3CB997 solid 1px;
  padding: 0px 6px;
  border-radius: 4rpx;
}

.step-right {
  color: #3CB997 !important;
  background-color: #E2F5EE !important;
  border: #3CB997 solid 1px;
  padding: 0px 6px;
  margin-right: 10rpx;
  border-radius: 4rpx;
}

.code_zone {
  background-color: #111827 !important;
  color: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx !important;
  padding: 16rpx 32rpx;
  margin-bottom: 24rpx;
}

/* 按钮统一绿色 */
.btn-full {
  height: 80rpx !important;
  border-radius: 20rpx !important;
  line-height: 80rpx !important;
  color: #3CB997 !important;
  background-color: #E2F5EE !important;
  text-align: center;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.step-title {
  line-height: 37px;
  font-size: 16px;
  color: #2A5548 !important;
}

.step-text{
  font-size: 14px;
  line-height: 24px;
  padding: 10px 0px;
  text-align: justify;
  color: #6B8A82 !important;
}

/* 弹窗 */
.modal-mask {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.2); z-index: 1000;
  display: flex; align-items: center; justify-content: center;
}
.modal-content {
  background: #fff; padding: 24px; border-radius: 24rpx !important; width: 80%;
}
.modal-title { font-size: 18px; margin-bottom: 16px; color: #2A5548 !important; }
.modal-input {
  margin-bottom: 12px;
  border: 1px solid #E2F5EE !important;
  padding: 8px;
  border-radius: 12rpx !important;
  width: 100%;
}
.modal-actions { display: flex; justify-content: flex-end; gap: 12px; }

/* ---------- AI 样式同步绿色 ---------- */
.notice-box {
  background: #F9FFF2;
  border-left: 4rpx solid #8CDB67;
  border-radius: 16rpx !important;
  padding: 20rpx 24rpx;
  margin: 20rpx 0;
}
.notice-text {
  font-size: 26rpx;
  color: #6B8A82 !important;
}
.shortcut-box {
  background-color: #FFFFFF !important;
  border-radius: 16rpx !important;
}
.shortcut-key {
  background-color: #E2F5EE !important;
  color: #3CB997 !important;
}
.plugin-name-box {
  background-color: #FFFFFF !important;
  border-left: 4rpx solid #3CB997 !important;
}
.plugin-name {
  color: #3CB997 !important;
}
.copy-btn {
  background-color: #E2F5EE !important;
}
.copy-text {
  color: #3CB997 !important;
}
.feature-item-with-examples {
  background-color: #FFFFFF !important;
}