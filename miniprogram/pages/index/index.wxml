<!-- 加载状态 -->
<view class="loading-container" wx:if="{{loading}}">
  <view class="loading">正在加载任务...</view>
</view>

<!-- 任务列表 -->
<view class="container" wx:else>
  <!-- 任务卡片循环 -->
  <view class="task-card" wx:for="{{list}}" wx:key="id">
    <!-- 任务类型标签 -->
    <view class="task-tag {{item.type}}">
      {{item.type === 'take' ? '顺路捎带' : item.type === 'ask' ? '咨询求助' : '即时搭伙'}}
    </view>
    
    <!-- 任务内容 -->
    <view class="task-content">{{item.content}}</view>
    
    <!-- 任务信息 -->
    <view class="task-info">
      <view class="task-user">发布者：{{item.nickname}}</view>
      <view class="task-time">{{item.time}}</view>
    </view>
    
    <!-- 任务操作按钮 -->
    <view class="task-action">
      <button class="btn-action" bindtap="acceptTask" data-id="{{item.id}}">
        接单
      </button>
    </view>
  </view>

  <!-- 空数据状态 -->
  <view class="empty-container" wx:if="{{list.length === 0 && !loading}}">
    <view class="empty-icon">📝</view>
    <view class="empty-text">还没有任务，快去发布吧！</view>
    <button class="btn-primary" bindtap="goPublish">
      发布任务
    </button>
  </view>
</view>