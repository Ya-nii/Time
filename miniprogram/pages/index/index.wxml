<view class="container">
  <view class="filter">
    <view 
      wx:for="{{filterList}}" 
      wx:key="type" 
      class="filter-item {{currentFilter == item.type ? 'active' : ''}}"
      bindtap="switchFilter"
      data-type="{{item.type}}"
    >
      {{item.name}}
    </view>
  </view>

  <view class="task-list">
    <view 
      class="task-item"
      wx:for="{{taskList}}" 
      wx:key="id"
    >
      <view class="task-label">{{item.templateLabel}}</view>
      <view class="task-content">{{item.content}}</view>
      <view class="task-time">{{item.createTime}}</view>

      <!-- 我已经帮你绑好 id 了！直接用！-->
      <button 
        class="take-btn"
        bindtap="takeTask" 
        data-id="{{item.id}}"
      >
        接单
      </button>
    </view>
  </view>
</view>