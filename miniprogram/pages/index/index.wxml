<view class="container">
  <view class="page-title">🎯 任务匹配大厅</view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view 
      class="filter-item {{currentFilter == item.type ? 'active' : ''}}"
      wx:for="{{filterList}}"
      wx:key="type"
      bindtap="switchFilter"
      data-type="{{item.type}}"
    >
      {{item.name}}
    </view>
  </view>

  <!-- 任务卡片列表 -->
  <view class="task-list">
    <view class="card" wx:for="{{taskList}}" wx:key="id">
      <!-- 标签 -->
      <view class="tag">{{item.templateLabel || (item.type == 'take' ? '顺路捎带' : item.type == 'ask' ? '即时咨询' : '紧急求助')}}</view>
      
      <!-- 内容 -->
      <view class="content" bindtap="goToDetail" data-id="{{item.id}}">
        {{item.content}}
      </view>
      
      <!-- 距离 + 时间 -->
      <view class="info">
        <text>🚶‍♂️ {{item.walkTime}} 分钟</text>
        <text>{{item.createTime}}</text>
      </view>
      
      <!-- 一键接单按钮 -->
      <view class="take-btn" bindtap="takeTask" data-id="{{item.id}}">
        一键接单
      </view>
    </view>
  </view>

  <view wx:if="{{isLoading}}" class="loading">加载中...</view>
</view>