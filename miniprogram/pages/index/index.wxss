/* pages/index/index.wxss */
.container {
  padding: 24rpx;
  background: #F2F9F6; /* 截图同款浅绿背景 */
  min-height: 100vh;
}

/* 筛选栏 */
.filter {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
  white-space: nowrap;
  padding: 0 8rpx;
}

.filter-item {
  padding: 14rpx 26rpx;
  background: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #6B8A82;
  border: 1rpx solid #E2F5EE;
}

.filter-item.active {
  background: #3CB997; /* 主绿色 */
  color: #fff;
  border: none;
}

/* 任务列表 */
.task-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 卡片放大、内边距拉满，更舒展 */
.task-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 36rpx 32rpx; /* 放大内边距，卡片更饱满 */
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  min-height: 220rpx; /* 固定卡片高度，保证按钮位置统一 */
}

.task-label {
  font-size: 26rpx;
  color: #3CB997;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.task-content {
  font-size: 32rpx;
  color: #2A5548;
  line-height: 1.6;
  margin-bottom: 16rpx;
  padding-right: 200rpx; /* 给按钮预留安全空间，不挡文字 */
}

.task-time {
  font-size: 24rpx;
  color: #6B8A82;
  position: absolute;
  left: 32rpx;
  bottom: 32rpx;
}

/* ✅ 接单按钮最终优化版 */
.take-btn {
  position: absolute;
  right: 32rpx;
  bottom: 32rpx;
  background: #3CB997;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 500;
  padding: 8rpx 40rpx; /* 精准尺寸：高度适中、宽度协调 */
  border-radius: 10rpx;
  border: none;
  line-height: 1.5;
  min-height: 60rpx; /* 固定高度，避免文字挤压变形 */
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 6rpx rgba(60, 185, 151, 0.15); /* 轻微阴影，提升层次感 */
}