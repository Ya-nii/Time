.container{
  padding: 30rpx;
  background: #f7f8fa;
  min-height: 100vh;
}
.page-title{
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #222;
}

.filter-bar{
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}
.filter-item{
  padding: 14rpx 28rpx;
  background: #fff;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
}
.filter-item.active{
  background: #07C160;
  color: #fff;
}

.card{
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  position: relative;
}
.tag{
  display: inline-block;
  background: #E6F7F2;
  color: #07C160;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}
.content{
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 20rpx;
}
.info{
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.take-btn{
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #07C160;
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
}
.loading{
  text-align: center;
  padding: 30rpx;
  color: #999;
}