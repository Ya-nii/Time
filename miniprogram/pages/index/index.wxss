/* pages/index/index.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 筛选栏 */
.filter {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-item {
  padding: 16rpx 28rpx;
  background: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #666;
}

.filter-item.active {
  background: #4A90E2;
  color: #fff;
}

/* 任务列表 */
.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  position: relative;
}

.task-label {
  font-size: 24rpx;
  color: #4A90E2;
  margin-bottom: 10rpx;
  font-weight: bold;
}

.task-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.task-time {
  font-size: 24rpx;
  color: #999;
}

/* 接单按钮 */
.take-btn {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  background: #4A90E2;
  color: white;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 10rpx;
  border: none;
}