/* 页面整体样式 */
.page {
  background-color: #f7f8fa; /* 浅灰背景，护眼 */
  min-height: 100vh;         /* 占满屏幕高度 */
  padding-bottom: 120rpx;    /* 给底部TabBar留空间 */
}

/* 任务列表容器 */
.task-list {
  padding: 20rpx; /* 左右内边距，避免内容贴边 */
}

/* 加载中状态 */
.loading {
  text-align: center;
  padding: 150rpx 0; /* 上下大间距，居中显示 */
  font-size: 28rpx;
  color: #999;       /* 浅灰色文字 */
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 150rpx 0;
  font-size: 28rpx;
  color: #999;
}

/* 任务卡片（核心：大卡片+单手操作） */
.task-card {
  background-color: #fff;       /* 白色背景 */
  border-radius: 24rpx;         /* 大圆角，视觉友好 */
  padding: 30rpx;               /* 内边距，内容不拥挤 */
  margin-bottom: 20rpx;         /* 卡片之间的间距 */
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); /* 轻微阴影，突出卡片 */
}

/* 任务类型标签 */
.task-type {
  font-size: 24rpx;
  color: #07c160; /* 绿色，醒目且友好 */
  margin-bottom: 16rpx;
}

/* 任务内容 */
.task-content {
  font-size: 32rpx;    /* 大号字体，方便步行时查看 */
  line-height: 1.5;    /* 行高，提升可读性 */
  color: #333;         /* 深灰色文字，清晰 */
  margin-bottom: 20rpx;
}

/* 任务信息栏（步行时间+发布时间） */
.task-info {
  display: flex;
  justify-content: space-between; /* 左右对齐 */
  font-size: 24rpx;
  color: #999;
}