<view class="mine-page">
  <!-- 1. 个人信息卡片（加大空间） -->
  <view class="card big-card">
    <view class="user-row">
      <image class="avatar" src="{{userInfo.avatarUrl}}"></image>
      <view class="user-info">
        <text class="nickname">{{userInfo.nickName}}</text>
        <text class="desc">完善资料</text>
      </view>
      <button class="edit-btn" bindtap="goToInfoEdit">编辑资料</button>
    </view>
  </view>

  <!-- 2. 积分卡片（长条形） -->
  <view class="card">
    <view class="score-row">
      <text class="score-label">我的积分</text>
      <text class="score-value">{{userInfo.score}}</text>
    </view>
  </view>

  <!-- 3. 积分规则（独立长条形） -->
  <view class="card func-card" bindtap="showScoreRule">
    <view class="func-row">
      <text class="func-text">积分规则</text>
      <text class="arrow">→</text>
    </view>
  </view>

  <!-- 4. 导入课程表（独立长条形） -->
  <view class="card func-card" bindtap="goToCourse">
    <view class="func-row">
      <text class="func-text">导入课程表</text>
      <text class="arrow">→</text>
    </view>
  </view>

  <!-- 5. 积分记录（长条形） -->
  <view class="card">
    <view class="record-row">
      <text class="record-title">积分记录</text>
      <text class="record-empty">暂无积分变动记录</text>
    </view>
  </view>
</view>