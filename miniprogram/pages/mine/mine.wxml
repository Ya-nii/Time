<view class="mine-page">
  <!-- 个人信息卡片 -->
  <view class="card big-card">
    <view class="user-row">
      <image class="avatar" src="/images/default-avatar.png"></image>
      <view class="user-info">
        <text class="nickname">{{userInfo.nickName || '未设置昵称'}}</text>
        <text class="desc">完善资料</text>
      </view>
      <button class="edit-btn" bindtap="goToInfoEdit">编辑资料</button>
    </view>
  </view>

  <!-- 积分卡片 -->
  <view class="card">
    <view class="score-row">
      <text class="score-label">我的积分</text>
      <text class="score-value">{{userInfo.score || 0}}</text>
    </view>
  </view>

  <!-- 每日签到入口（可跳转） -->
  <view bindtap="goToSign">
    <view class="card func-card">
      <view class="func-row">
        <text class="func-text">每日签到</text>
        <view style="display:flex;align-items:center;">
          <text wx:if="{{continuousDays > 0}}" style="color:#07c160;font-size:24rpx;margin-right:10rpx;">连续{{continuousDays}}天</text>
          <icon type="arrowright" size="20" color="#07c160"></icon>
        </view>
      </view>
    </view>
  </view>

  <!-- 积分规则入口 -->
  <view bindtap="showScoreRule">
    <view class="card func-card">
      <view class="func-row">
        <text class="func-text">积分规则</text>
        <icon type="arrowright" size="20" color="#07c160"></icon>
      </view>
    </view>
  </view>

  <!-- 校园认证 -->
  <view bindtap="goVerify">
    <view class="card func-card">
      <view class="func-row">
        <text class="func-text">校园认证</text>
        <icon type="arrowright" size="20" color="#07c160"></icon>
      </view>
    </view>
  </view>

  <!-- 导入课程表入口 -->
  <view bindtap="goToCourse">
    <view class="card func-card">
      <view class="func-row">
        <text class="func-text">导入课程表</text>
        <icon type="arrowright" size="20" color="#07c160"></icon>
      </view>
    </view>
  </view>

  <!-- 积分记录卡片 → 现在可以点了！跳转到积分明细！ -->
  <view bindtap="goScoreDetail">
    <view class="card">
      <view class="record-row">
        <text class="record-title">积分记录</text>
        <text class="record-empty">暂无积分变动记录</text>
      </view>
    </view>
  </view>
</view>