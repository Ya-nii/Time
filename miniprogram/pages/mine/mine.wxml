<view class="container">
  <!-- 顶部个人信息栏 -->
  <view class="user-header">
    <image class="avatar" src="/images/default-avatar.png"></image>
    <view class="info">
      <text class="name">{{userInfo.nickName || '未设置昵称'}}</text>
      <text class="tip">完善资料</text>
    </view>
    <button class="edit" bindtap="goToInfoEdit">编辑资料</button>
  </view>

  <!-- 积分卡片 -->
  <view class="score-card">
    <text>我的积分</text>
    <text class="score">{{userInfo.score || 0}}</text>
  </view>

  <!-- 功能菜单网格 -->
  <view class="menu-grid">
    <view class="item" bindtap="goToSign">
      <text class="icon">📅</text>
      <text>每日签到</text>
      <text wx:if="{{continuousDays>0}}" class="tag">连续{{continuousDays}}天</text>
    </view>

    <view class="item" bindtap="showScoreRule">
      <text class="icon">📜</text>
      <text>积分规则</text>
    </view>

    <view class="item" bindtap="goVerify">
      <text class="icon">🎓</text>
      <text>校园认证</text>
    </view>

    <view class="item" bindtap="goToCourse">
      <text class="icon">📚</text>
      <text>导入课程表</text>
    </view>

    <view class="item" bindtap="goToMyTask">
      <text class="icon">📋</text>
      <text>我的任务</text>
    </view>

    <view class="item" bindtap="goScoreDetail">
      <text class="icon">📊</text>
      <text>积分记录</text>
    </view>
  </view>
</view>