.mine-page {
  background-color: #f7f8fa;
  min-height: 100vh;
  padding: 30rpx 25rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 25rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.05);
}

.big-card {
  padding: 35rpx 25rpx;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background-color: #e5e5e5;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.nickname {
  font-size: 34rpx;
  color: #333;
  font-weight: 500;
}

.desc {
  font-size: 24rpx;
  color: #999;
}

.edit-btn {
  width: 130rpx;
  height: 50rpx;
  font-size: 24rpx;
  color: #07c160;
  background-color: #e8f5e9;
  border: none;
  border-radius: 25rpx;
  padding: 0;
}

.score-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.score-label {
  font-size: 28rpx;
  color: #666;
}

.score-value {
  font-size: 36rpx;
  color: #07c160;
  font-weight: bold;
}

.func-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.func-text {
  font-size: 28rpx;
  color: #333;
}

.record-row {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.record-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.record-empty {
  font-size: 26rpx;
  color: #999;
}