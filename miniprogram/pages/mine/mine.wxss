page {
  background: #f5f7fa;
}
.page {
  padding: 20rpx;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
}
.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  object-fit: cover;
  background: #f0f0f0;
}
.user-info {
  flex: 1;
  margin-left: 24rpx;
}
.nickname {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}
.tag {
  font-size: 24rpx;
  color: #0099ff;
  background: #e6f7ff;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}
.info-link {
  font-size: 26rpx;
  color: #999;
}

/* 图标快捷栏 */
.icon-bar {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx 0;
  margin-bottom: 30rpx;
}
.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.icon {
  width: 70rpx;
  height: 70rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 10rpx;
}
.label {
  font-size: 24rpx;
  color: #666;
}

/* 权益卡片 */
.benefit-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.benefit-row {
  display: flex;
}
.benefit-item {
  text-align: center;
}
.num {
  font-size: 44rpx;
  font-weight: bold;
  color: #07c160;
}
.name {
  font-size: 26rpx;
  color: #666;
}

/* 列表卡片 */
.list-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}
.list-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.list-item:last-child {
  border-bottom: none;
}
.item-icon {
  font-size: 34rpx;
  margin-right: 20rpx;
}
.item-text {
  flex: 1;
  font-size: 29rpx;
}
.tag-text {
  font-size: 24rpx;
  color: #07c160;
  margin-right: 10rpx;
}
.arrow {
  font-size: 28rpx;
  color: #ccc;
}