/* 整体背景 */
.container {
  background: #f7f8fa;
  min-height: 100vh;
  padding: 20rpx;
}

/* 顶部用户栏 */
.user-header {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: #eee;
}

.info {
  flex: 1;
  margin-left: 20rpx;
}

.name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.tip {
  font-size: 24rpx;
  color: #999;
}

.edit {
  font-size: 24rpx;
  color: #07c160;
  background: none;
  border: 1rpx solid #07c160;
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
}

/* 积分卡片 */
.score-card {
  background: linear-gradient(90deg, #07c160, #06a855);
  color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.score {
  font-size: 48rpx;
  font-weight: bold;
}

/* 功能宫格 */
.menu-grid {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  flex-wrap: wrap;
}

.item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  position: relative;
}

.icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.item text {
  font-size: 26rpx;
  color: #333;
}

.tag {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background: #e6f7f0;
  color: #8bea9c !important;
  font-size: 20rpx !important;
  padding: 4rpx 8rpx;
  border-radius: 10rpx;
}