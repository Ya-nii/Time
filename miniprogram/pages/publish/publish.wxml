<view class="container">
  <view class="title">发布任务</view>

  <!-- 任务模板 -->
  <view class="template-group">
    <view class="template {{currentTemplate.type === 'take' ? 'active' : ''}}"
      bindtap="selectTemplate"
      data-type="take"
      data-label="顺路捎带">
      顺路捎带
    </view>
    <view class="template {{currentTemplate.type === 'ask' ? 'active' : ''}}"
      bindtap="selectTemplate"
      data-type="ask"
      data-label="即时咨询">
      即时咨询
    </view>
    <view class="template {{currentTemplate.type === 'team' ? 'active' : ''}}"
      bindtap="selectTemplate"
      data-type="team"
      data-label="紧急求助">
      紧急求助
    </view>
  </view>

  <!-- 输入框 -->
  <textarea class="input"
    value="{{taskContent}}"
    bindinput="onInput"
    placeholder="请填写任务详情">
  </textarea>

  <!-- 发布按钮 -->
  <button class="publish-btn" bindtap="onPublishTask">
    发布任务
  </button>
</view>