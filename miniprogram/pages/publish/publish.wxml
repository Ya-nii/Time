<view class="publish-page">
  <!-- 任务类型选择器（小按钮） -->
  <view class="type-selector">
    <view 
      class="type-btn {{currentType === item.type ? 'active' : ''}}"
      wx:for="{{typeList}}" wx:key="type"
      data-type="{{item.type}}"
      bindtap="selectType"
    >
      {{item.name}}
    </view>
  </view>

  <!-- 输入卡片（缩小高度） -->
  <view class="input-card">
    <textarea 
      class="content-input"
      value="{{content}}"
      bindinput="onInput"
      placeholder="可修改模板内容或语音输入"
      maxlength="200"
    ></textarea>
    
    <!-- 语音按钮（缩小） -->
    <button 
      class="voice-btn {{isRecording ? 'recording' : ''}}"
      bindtap="toggleVoiceInput"
    >
      🎤 {{isRecording ? '停止录音' : '语音输入'}}
    </button>
  </view>

  <!-- 发布按钮（缩小） -->
  <button class="submit-btn" bindtap="submit">
    发布任务
  </button>
</view>