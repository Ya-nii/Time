.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #F2F9F6;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #2A5548;
}

.template-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 25rpx;
  margin-bottom: 30rpx;
}

.template-group {
  display: flex;
  gap: 20rpx;
}

.template {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  border: 1rpx solid #E2F5EE;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #6B8A82;
}

.template.active {
  background: #3CB997;
  color: #fff;
  border-color: #3CB997;
}

.input-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  position: relative;
  margin-bottom: 40rpx;
}

.task-input {
  width: 100%;
  height: 220rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  padding-right: 100rpx;
  padding-bottom: 20rpx;
}

/* 图标按钮容器（为了适配更大的图标，我也稍微放大了一点） */
.location-icon {
  position: absolute;
  right: 35rpx;
  bottom: 35rpx;
  width: 72rpx;
  height: 72rpx;
  background: #E2F5EE;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  box-shadow: 0 3rpx 10rpx rgba(60, 185, 151, 0.1);
}

/* 图标大小从 36rpx 放大到了 44rpx */
.icon-img {
  width: 55rpx;
  height: 55rpx;
}

.publish-area {
  margin-top: 20rpx;
}

.publish-btn {
  width: 100%;
  background: #3CB997;
  color: #fff;
  border-radius: 24rpx;
  height: 88rpx;
  font-size: 30rpx;
  border: none;
}