.publish-container {
  padding: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 类型选择 */
.type-select {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.type-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  color: #666;
  font-size: 28rpx;
}

.type-item.active {
  background: #007aff;
  color: #fff;
}

/* 输入框 */
.input-area {
  width: 100%;
  min-height: 400rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  font-size: 32rpx;
  line-height: 1.6;
  border: 1px solid #eee;
  box-sizing: border-box;
}

/* 字数统计 */
.count {
  text-align: right;
  margin: 15rpx 0 30rpx 0;
  color: #999;
  font-size: 24rpx;
}

/* 发布按钮 */
.submit-btn {
  background: linear-gradient(135deg, #007aff 0%, #5856d6 100%);
  color: #fff;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border: none;
}

.submit-btn[disabled] {
  background: #ccc;
}