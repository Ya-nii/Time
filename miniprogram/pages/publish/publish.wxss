.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f8f9fa;
}
.header {
  text-align: center;
  margin-bottom: 30rpx;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
}
.template-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 25rpx;
  margin-bottom: 30rpx;
}
.template-group {
  display: flex;
  gap: 20rpx;
}
.template {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  font-size: 26rpx;
}
.template.active {
  background: #07c160;
  color: #fff;
  border-color: #07c160;
}
.input-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  position: relative;
  margin-bottom: 40rpx;
}
.task-input {
  width: 100%;
  height: 220rpx;
  font-size: 28rpx;
}
/* 定位图标 */
.location-icon {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  font-size: 36rpx;
  z-index: 999;
}
.publish-btn {
  width: 100%;
  background: #07c160;
  color: #fff;
  border-radius: 20rpx;
  height: 88rpx;
  font-size: 30rpx;
}