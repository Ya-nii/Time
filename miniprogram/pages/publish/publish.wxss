.container{
  padding: 30rpx;
  background: #f6f7f9;
  min-height: 100vh;
}
.title{
  font-size: 38rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
}
.template-group{
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}
.template{
  flex:1;
  background:#fff;
  border-radius:16rpx;
  padding:24rpx;
  text-align:center;
  font-size:26rpx;
}
.template.active{
  background:#07c160;
  color:#fff;
}
.input{
  width:100%;
  height:240rpx;
  background:#fff;
  border-radius:16rpx;
  padding:20rpx;
  font-size:28rpx;
  box-sizing:border-box;
  margin-bottom:40rpx;
}
.publish-btn{
  background:#07c160;
  color:#fff;
  border-radius:44rpx;
  height:88rpx;
  font-size:32rpx;
}