/* 页面整体：保持浅灰背景 */
.publish-page {
  background: #f7f8fa;
  min-height: 100vh;
  padding: 30rpx 25rpx;
  display: flex;
  flex-direction: column;
}

/* 任务类型选择器：缩小按钮高度 */
.type-selector {
  display: flex;
  gap: 15rpx;
  margin-bottom: 25rpx;
}
.type-btn {
  flex: 1;
  padding: 18rpx 0;
  text-align: center;
  font-size: 26rpx;
  background: #fff;
  border-radius: 12rpx;
  color: #666;
  box-shadow: 0 1rpx 5rpx rgba(0,0,0,0.05);
}
.type-btn.active {
  background: #07c160;
  color: #fff;
}

/* 输入卡片：缩小高度和内边距 */
.input-card {
  flex: 1;
  max-height: 500rpx; /* 限制卡片最大高度 */
  background: #fff;
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 25rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
}
.content-input {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
  padding: 0;
  margin-bottom: 20rpx;
  min-height: 200rpx; /* 缩小输入框高度 */
}
.voice-btn {
  height: 60rpx;
  font-size: 24rpx;
  border-radius: 30rpx;
  background: #f0f0f0;
  color: #333;
  border: none;
  padding: 0 30rpx;
  align-self: center; /* 居中显示，更紧凑 */
}
.voice-btn.recording {
  background: #ff4d4f;
  color: #fff;
}

/* 发布按钮：缩小高度 */
.submit-btn {
  height: 70rpx;
  font-size: 28rpx;
  border-radius: 35rpx;
  background: #07c160;
  color: #fff;
  border: none;
}