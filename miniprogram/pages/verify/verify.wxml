<view class="container">
  <view class="title">校园认证</view>

  <view class="item">
    <text>姓名</text>
    <input placeholder="请输入真实姓名" bindinput="inputName" />
  </view>

  <view class="item">
    <text>学号</text>
    <input placeholder="请输入学号" bindinput="inputStuId" />
  </view>

  <button class="btn" bindtap="submit">提交认证</button>
</view>