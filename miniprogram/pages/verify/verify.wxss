.container {
  padding: 40rpx;
  background: #f7f7f7;
  min-height: 100vh;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
}

.item {
  background: #fff;
  padding: 25rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

input {
  margin-top: 10rpx;
  font-size: 28rpx;
}

.btn {
  margin-top: 40rpx;
  background: #07c160;
  color: #fff;
  border-radius: 16rpx;
}